# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_exchange
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Cache — swap provider without code changes
# Options: memory | ioredis | upstash
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# MPP / Tempo
TEMPO_WALLET_ADDRESS=0x...
TEMPO_WALLET_PRIVATE_KEY=
MPP_CHALLENGE_TTL_SECONDS=300

# Admin
ADMIN_API_KEY=replace-with-32-byte-hex

# Rate limiting
RATE_LIMIT_PUBLIC_RPM=60
RATE_LIMIT_PREMIUM_RPM=300

# Cron authentication
CRON_SECRET=replace-with-random-secret

# Future (deferred — leave blank)
VOLTAGE_API_KEY=
VOLTAGE_NODE_ID=
GCP_PROJECT_ID=
GCP_REGION=us-central1
AWS_ACCOUNT_ID=
AWS_REGION=us-east-1
