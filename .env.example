# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth
AUTH_BYPASS=false
NEXT_PUBLIC_AUTH_BYPASS=false
ADMIN_EMAILS=

# Database
# Local Docker/Postgres defaults:
# DATABASE_URL  — runtime connection used by the app
# DIRECT_URL    — migration/introspection connection used by Prisma
#
# Supabase (IPv4-friendly, with connection pooling) usually looks like:
# DATABASE_URL=postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true
# DIRECT_URL=postgresql://postgres.<ref>:<password>@aws-<region>.pooler.supabase.com:5432/postgres
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_exchange?pgbouncer=true
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/agent_exchange

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Cache — swap provider without code changes
# Options: memory | ioredis | upstash
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MPP / Tempo
TEMPO_WALLET_ADDRESS=0x...
TEMPO_API_KEY=
MPP_CHALLENGE_TTL_SECONDS=300

# x402 — USDC payments on Base via EIP-712 + Coinbase CDP facilitator
# Get free testnet USDC (Base Sepolia): https://faucet.circle.com
# x402 spec: https://www.x402.org  |  SDK: https://github.com/coinbase/x402
X402_PAY_TO_ADDRESS=0x...      # EVM wallet address that receives USDC payments
X402_NETWORK=base-sepolia      # base-sepolia (testnet) | base (mainnet)
