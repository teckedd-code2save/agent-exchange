# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001

# Auth
AUTH_BYPASS=false
NEXT_PUBLIC_AUTH_BYPASS=false
ADMIN_EMAILS=

# Database
# DATABASE_URL  — pooled connection (PgBouncer port 6543), add ?pgbouncer=true
# DIRECT_URL    — direct connection (port 5432), used by Prisma migrations
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agent_exchange?pgbouncer=true
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/agent_exchange

# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Cache — swap provider without code changes
# Options: memory | ioredis | upstash
CACHE_PROVIDER=memory
REDIS_URL=redis://localhost:6379
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# MPP / Tempo
TEMPO_WALLET_ADDRESS=0x...
TEMPO_API_KEY=
MPP_CHALLENGE_TTL_SECONDS=300
