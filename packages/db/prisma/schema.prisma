// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Status {
  draft
  sandbox
  testnet
  live
  paused
}

enum PricingType {
  fixed
  per_token
  per_second
}

enum PaymentType {
  tempo
  stripe
  lightning
  sandbox // For testing without real rails
}

enum CallerType {
  anonymous
  identified_agent
  user_proxy
}

enum Environment {
  sandbox
  testnet
  production
}

// ─── Models ──────────────────────────────────────────────────────────────────

// 1. Providers (Users/Devs who own services)
model Provider {
  id      String  @id @default(cuid())
  userId  String  @unique // Link to Clerk/Supabase Auth
  name    String?
  email   String  @unique
  company String?

  // Balances for testnet faucet
  testnetBalance Decimal @default(0.0)
  liveBalance    Decimal @default(0.0)

  services Service[]
  apiKeys  ApiKey[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Services (The core entity - the AI APIs)
model Service {
  id          String   @id @default(cuid())
  name        String
  description String
  providerId  String
  provider    Provider @relation(fields: [providerId], references: [id])

  // Routing
  endpoint   String // The actual API URL
  studioSlug String @unique // The mpp.studio/api/v1/slug proxy endpoint

  status Status @default(draft)

  // Discovery
  category String // "image-generation", "search", "data", etc.
  tags     String[]

  // Pricing configuration
  pricingType   PricingType @default(fixed)
  pricingConfig Json // { amount: "0.005", currency: "USDC" }

  // Per-endpoint configuration (method, path, description, payment config)
  endpoints Json? // Array of { method, path, description, payment: { amount, currency, ... } }

  // MPP specific settings
  mppChallengeEndpoint String? // Override for where to send 402s if different from endpoint
  supportedPayments    PaymentType[]

  // Denormalized analytics
  totalCalls   Int     @default(0)
  totalRevenue Decimal @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  calls   Call[]
  reviews Review[]

  @@index([category, status])
}

// 3. API Keys (For accessing the Studio Proxy and Discovery)
model ApiKey {
  id          String      @id @default(cuid())
  key         String      @unique
  providerId  String
  provider    Provider    @relation(fields: [providerId], references: [id])
  environment Environment @default(sandbox)
  name        String // "Dev key", "Prod key"
  lastUsedAt  DateTime?

  createdAt DateTime  @default(now())
  expiresAt DateTime?
}

// 4. Calls (The transaction log / Ledger)
model Call {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  // Who called (agents)
  callerType CallerType @default(anonymous)
  callerId   String? // If identified agent

  // The request
  method String // GET, POST
  path   String // The path appended to the service
  status Int // 200, 402, 500

  // Payment details
  paymentType PaymentType
  amount      Decimal
  currency    String // USDC, USD, BTC

  // MPP flow tracking
  challengeIssued Boolean @default(false)
  challengeSolved Boolean @default(false)
  receiptVerified Boolean @default(false)

  // Performance
  latencyMs Int

  // Environment tracking
  environment Environment @default(sandbox)

  createdAt DateTime @default(now())

  @@index([serviceId, createdAt])
  @@index([serviceId, status])
  @@index([environment, createdAt])
}

// 5. Reviews (Agent Attestation)
model Review {
  id        String  @id @default(cuid())
  serviceId String
  service   Service @relation(fields: [serviceId], references: [id])

  reviewerId String // Agent or user identifier
  rating     Int // 1-5
  comment    String?
  callId     String? @unique // Optional link to specific transaction (Proof of Usage)

  createdAt DateTime @default(now())

  @@index([serviceId, rating])
}

// 6. Testnet Faucet Claims (Rate limiting faucet)
model FaucetClaim {
  id       String  @id @default(cuid())
  walletId String // Address or identifier
  amount   Decimal
  currency String  @default("USDC")
  network  String  @default("tempo-testnet")

  createdAt DateTime @default(now())

  @@index([walletId, createdAt])
}
